{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*", "../../packages/ui/src/**/*", "vite.config.ts", "global.d.ts"],
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "rootDir": "../..",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@pianel/core/*": ["../../packages/core/dist/*"],
      "@pianel/ui/*": ["../../packages/ui/src/*"]
    }
  }
}
