{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*", "../../packages/ui/src/**/*"],
  "compilerOptions": {
    "composite": true,
    "outDir": "out",
    "rootDir": "../..",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "typeRoots": ["../../node_modules/@types", "./node_modules/@types"],
    "paths": {
      "@pianel/core/*": ["../../packages/core/dist/*"],
      "@pianel/ui/*": ["../../packages/ui/src/*"]
    }
  }
}
