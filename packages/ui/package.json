{
  "name": "@pianel/ui",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/App.tsx",
    "./App": "./src/App.tsx",
    "./store": "./src/store/index.ts",
    "./styles/global.css": "./src/styles/global.css",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./host/*": "./src/host/*.ts",
    "./screens/*": "./src/screens/*.tsx",
    "./transport/*": "./src/transport/*.ts"
